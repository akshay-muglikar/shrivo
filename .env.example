# Database — asyncpg format
# For the bundled Docker db service, host must be "db" (Docker internal DNS)
# For an external database, replace with your host/port
DATABASE_URL=postgresql+asyncpg://inventory:your_password@db:5432/inventory

# Postgres container credentials (only used by the "db" service in docker-compose)
POSTGRES_USER=inventory
POSTGRES_PASSWORD=your_password
POSTGRES_DB=inventory

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_random_secret_key
ACCESS_TOKEN_EXPIRE_DAYS=30

# WhatsApp (Twilio) — leave blank to disable
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App
PORT=8000
ENVIRONMENT=production
CORS_ORIGINS=["http://localhost"]
TIMEZONE=Asia/Kolkata

# Deployment
DOMAIN=yourdomain.com
APP_PORT=80
